<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Jarvis is not sandboxed (it uses Accessibility + CGEvent to control apps).
	     Under the hardened runtime it still needs to send Apple events to drive
	     Mail and Notes. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
